{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "ADMIN_APP_URL",
        "AWS_ACCESS_KEY_ID",
        "AWS_REGION",
        "AWS_S3_BUCKET_NAME",
        "AWS_SECRET_ACCESS_KEY",
        "BACKEND_URL",
        "BETTER_AUTH_BASE_URL",
        "BETTER_AUTH_SECRET",
        "CDN_BASE_URL",
        "DATABASE_URL",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "NEO4J_PASSWORD",
        "NEO4J_URI",
        "NEO4J_USERNAME",
        "NEXT_PUBLIC_ADMIN_URL",
        "NEXT_PUBLIC_API_URL",
        "NODE_ENV",
        "OPENAI_API_KEY",
        "QDRANT_API_KEY",
        "QDRANT_ENV",
        "QDRANT_URI",
        "TOKEN_DAILY_LIMIT",
        "VALKEY_HOST",
        "VALKEY_PORT",
        "VALKEY_URL"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**","dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
