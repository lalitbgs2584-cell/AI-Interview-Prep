generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  // Resume
  isResumeUploaded Boolean    @default(false)
  // Soft delete
  isDeleted        Boolean    @default(false)
  isBlocked        Boolean    @default(false)
  isBlockedReason  String     @default("")
  isBlockedAt      DateTime?
  streak           Int        @default(0) // current login streak (days)
  bestStreak       Int        @default(0) // all-time best streak
  lastLoginAt      DateTime? // track for streak logic
  activityMap      Json       @default("{}") // ISO-date → session count map
  role             UserRole   @default(USER)
  gapReport        GapReport?

  interviews Interview[]
  skills     UserSkill[]
  files      File[]
  resumes    Resume[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ENUMS

enum UserRole {
  USER
  ADMIN
}

enum InterviewStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InterviewType {
  TECHNICAL
  HR
  SYSTEM_DESIGN
  BEHAVIORAL
}

enum FileStatus {
  STARTING
  UPLOADED
  PROCESSED
  FAILED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

// SKILLS

model Skill {
  id       String  @id @default(uuid())
  name     String  @unique
  category String?

  users UserSkill[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("skill")
}

model UserSkill {
  userId  String
  skillId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([userId])
  @@index([skillId])
  @@map("user_skill")
}

// INTERVIEWS

model Interview {
  id          String  @id @default(uuid())
  title       String
  description String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  videoUrl           String?
  status             InterviewStatus @default(CREATED)
  type               InterviewType   @default(TECHNICAL)
  endReason          String?
  interruptionCount  Int?
  tabSwitches        Int             @default(0)
  fsExits            Int             @default(0)
  sessionDurationSec Int             @default(0)

  questions InterviewQuestion[]

  summary     InterviewSummary?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  completedAt DateTime?

  @@index([userId])
  @@index([status])
  @@map("interview")
}

model File {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  url              String
  OriginalFileName String
  fileType         String
  S3FileName       String
  status           FileStatus @default(STARTING)

  resumes   Resume?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("file")
}

model Resume {
  id             String   @id @default(uuid())
  userId         String   @unique
  fileId         String   @unique
  neo4jNodeId    String?
  qdrantPointIds String[] @default([])
  storedInNeo4j  Boolean  @default(false)
  storedInQdrant Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  workExperience  WorkExperience[]
  education       Education[]
  projects        Project[]
  extracurricular Extracurricular[]
  insights        Insights?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId])
  @@map("resume")
}

model Insights {
  id              String   @id @default(uuid())
  resumeId        String   @unique
  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  experienceLevel Int      @default(0)
  keySkills       String[]
  ATSSCORE        Int      @default(0)
  strongDomains   String[] @default([])
  weakAreas       String[] @default([])

  @@index([resumeId])
  @@map("insights")
}

model Extracurricular {
  id       String @id @default(uuid())
  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  title        String
  organization String?
  duration     String?
  description  String?

  createdAt DateTime @default(now())

  @@index([resumeId])
  @@map("extracurricular")
}

model Project {
  id       String @id @default(uuid())
  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  title       String
  techStack   String[] // postgres array
  description String?

  createdAt DateTime @default(now())

  @@index([resumeId])
  @@map("project")
}

model Education {
  id       String @id @default(uuid())
  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  institution String
  degree      String
  duration    String?
  grade       String?

  createdAt DateTime @default(now())

  @@index([resumeId])
  @@map("education")
}

model WorkExperience {
  id       String @id @default(uuid())
  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  company     String?
  role        String?
  duration    String?
  description String?

  createdAt DateTime @default(now())

  @@index([resumeId])
  @@map("work_experience")
}

model GapReport {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // { concept: cumulativeCount } — merged from all interview gap_frequency maps
  conceptFrequency Json @default("{}")

  // concepts appearing as a gap in 2+ interviews
  persistentGaps String[] @default([])

  // dimension name → average score across all interviews (0–10)
  dimensionAverages Json @default("{}")

  // ISO date of most recent interview factored in
  lastUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
  @@index([userId])
  @@map("gap_report")
}

model InterviewSummary {
  id String @id @default(uuid())

  interviewId String    @unique
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  // ── Deterministic scores ──────────────────────────────────────────────────
  overallScore    Int    @default(0) // 0–100, difficulty-weighted
  plainAvg        Float  @default(0) // simple 0–10 average
  weightedAvg     Float  @default(0) // difficulty-weighted 0–10 average
  recommendation  String @default("Needs More Evaluation")
  durationSeconds Int    @default(0)

  // ── LLM-narrated content ──────────────────────────────────────────────────
  summary String?

  // { point: string, tag: string }[]
  whatWentRight Json @default("[]")
  whatWentWrong Json @default("[]")

  tips String[] @default([])

  // ── Skill dimension scores ────────────────────────────────────────────────
  // { "Technical Depth": 72, "Communication": 80, ... }
  skillScores Json @default("{}")

  // ── Per-question score snapshots ──────────────────────────────────────────
  // [{ index, score(0-100), difficulty, question, verdict, missing_concepts[], ... }]
  questionScores Json @default("[]")

  // ── Gap analysis (fully deterministic) ────────────────────────────────────
  // { repeated_gaps[], all_gaps[], gap_frequency{}, weak_dimensions[], dim_averages{} }
  gapAnalysis Json @default("{}")

  contentQuality     String?
  deliveryQuality    String?
  interviewIntegrity String?
  endReason          String?
  isEarlyExit        Boolean @default(false)
  interruptionCount  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([interviewId])
  @@map("interview_summary")
}

model Question {
  id         String         @id @default(uuid())
  content    String
  difficulty Difficulty?
  type       InterviewType?

  // NEW — expected answer metadata for comparative evaluation
  expectedAnswer Json? // { key_concepts[], reasoning_steps[], ideal_structure, common_mistakes[] }

  interviews InterviewQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([difficulty])
  @@index([type])
  @@map("question")
}

// ─────────────────────────────────────────────────────────────────────────────
// 2. REPLACE the existing InterviewQuestion model
//    Add: expectedAnswer Json? — per-interview snapshot of expected answer
//         (decoupled from the Question bank to allow per-session customisation)
// ─────────────────────────────────────────────────────────────────────────────

model InterviewQuestion {
  id String @id @default(uuid())

  interviewId String
  questionId  String

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  question  Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  response Response?

  order Int?
  score Int?

  // NEW — snapshot of the expected answer used during this interview session
  referenceAnswer String?

  createdAt DateTime @default(now())

  @@unique([interviewId, questionId])
  @@index([interviewId])
  @@index([questionId])
  @@map("interview_question")
}

// ─────────────────────────────────────────────────────────────────────────────
// 3. REPLACE the existing Response model
//    Add: userAnswer String? — stores the raw text of the candidate's answer
// ─────────────────────────────────────────────────────────────────────────────

model Response {
  id String @id @default(uuid())

  interviewQuestionId String            @unique
  interviewQuestion   InterviewQuestion @relation(fields: [interviewQuestionId], references: [id], onDelete: Cascade)

  // NEW — the candidate's actual answer text
  userAnswer  String?
  submittedAt DateTime?

  evaluation Evaluation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([interviewQuestionId])
  @@map("response")
}

model Evaluation {
  id String @id @default(uuid())

  responseId String   @unique
  response   Response @relation(fields: [responseId], references: [id], onDelete: Cascade)

  // ── Scores ────────────────────────────────────────────────────────────────
  overallScore    Int? // 0–10 (difficulty-capped)
  overallScore100 Int? // 0–100 convenience field (overallScore * 10)
  confidence      Float? // LLM confidence 0.0–1.0

  dimensions Json?

  // ── Comparative analysis (NEW) ────────────────────────────────────────────
  missingConcepts String[] @default([]) // key concepts absent from the answer
  incorrectPoints String[] @default([]) // factual errors or misconceptions

  // ── Per-answer verdict (strict, replaces vague "feedback") ────────────────
  strengths  String[] @default([]) // specific things done well
  weaknesses String[] @default([]) // specific gaps, named explicitly
  verdict    String? // 1-line brutally honest summary

  // ── Follow-up ─────────────────────────────────────────────────────────────
  followup         Boolean @default(false)
  followupQuestion String?

  // ── Legacy fields kept for backward compatibility ─────────────────────────
  clarity      Int?
  technical    Int?
  improvements String?
  feedback     String? // mirrors verdict for backward compat

  whyScoreNotHigher    String?
  evidenceSnippets     String[]  @default([]) 
  responseAnalyticsMetrics Json? 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("evaluation")
}
